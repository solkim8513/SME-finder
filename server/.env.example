# Server
PORT=5001
DATABASE_URL=postgresql://sme_user:sme_pass@db:5432/sme_finder
JWT_SECRET=change_this_to_a_long_random_string
CLIENT_URL=http://localhost:3100

# Email (SMTP) — leave blank to disable email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SME Finder <noreply@yourcompany.com>"

# Microsoft Teams — paste your incoming webhook URL here, leave blank to disable
TEAMS_WEBHOOK_URL=

# Public URL used in one-click response links (what SMEs/PMs see in emails)
APP_PUBLIC_URL=http://localhost:3100
